NEXT_PUBLIC_SITE_URL=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# Paystack Plan codes. Foundation is billed only once its 7-day free trial
# ends (never attached at signup — see src/app/api/trial/convert). Growth
# offers monthly or annual billing under the same feature tier. Enterprise
# has no live checkout yet.
PAYSTACK_PLAN_FOUNDATION=
PAYSTACK_PLAN_GROWTH_MONTHLY=
PAYSTACK_PLAN_GROWTH_ANNUAL=
PAYSTACK_PLAN_ENTERPRISE=

# Shared secret the daily trial-reminder GitHub Action sends as a header so
# the cron route can't be triggered by anyone else. Generate with:
# openssl rand -hex 32
CRON_SECRET=

# Used to encrypt/decrypt growth_client_secrets.meta_capi_access_token_encrypted
# before it ever touches the database. Generate with: openssl rand -hex 32
APP_ENCRYPTION_KEY=

# Drafts landing page copy from a client's onboarding business profile
# (src/lib/ai/draft-copy.ts). Best-effort — onboarding works fine without
# this set, the client just gets a blank Landing Copy step to fill in
# themselves instead of an AI-drafted starting point.
ANTHROPIC_API_KEY=

# Comma-separated allowlist gating /admin. Not a secret, just a whitelist.
ADMIN_EMAILS=

# Replaces Supabase's rate-limited built-in mailer for the lead-notification
# email. Also configure as Supabase Auth's custom SMTP relay (dashboard
# setting, not code) for signup/invite emails to fully avoid the rate limit.
RESEND_API_KEY=

# Sender for every email sendEmail() sends. Must be an address on a domain
# verified in Resend (Domains tab) — otherwise Resend silently restricts
# delivery to only the account owner's own inbox.
RESEND_FROM_EMAIL=

# Stock photo search for clients with no upload-ready images of their own.
# Free tier, no expiry. pexels.com/api
PEXELS_API_KEY=

# DigitalFlyer Core's WhatsApp number (international format, no +/spaces),
# used for the marketplace-listing request CTA. Left unset until Meta
# verification clears — the CTA shows "Coming soon" until this is set.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Rate & Review Sprint 1: Cloudflare Turnstile on the review submission
# form. dash.cloudflare.com → Turnstile → Add widget.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google Analytics (GA4). analytics.google.com → Admin → Data Streams → your
# web stream → Measurement ID. Root layout renders nothing if unset.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# DigitalFlyer's own Meta Pixel, for the marketing site itself (pricing,
# marketplace, events, faq, agents/apply) — separate from a client's own
# pixel (growth_clients.meta_pixel_id, entered per-client in their
# dashboard). business.facebook.com → Events Manager → Connect Data
# Sources → Web → Meta Pixel → create one → copy the Pixel ID (a 15-16
# digit number). MarketingHeader renders nothing if unset.
NEXT_PUBLIC_DIGITALFLYER_META_PIXEL_ID=

# Error monitoring (src/sentry.server.config.ts, sentry.edge.config.ts,
# instrumentation-client.ts). sentry.io → create a free account → New
# Project → Next.js → copy the DSN shown during setup. Sentry.init() safely
# no-ops on every request until this is set, same as GA4 above.
NEXT_PUBLIC_SENTRY_DSN=

# Optional, only needed for readable (un-minified) stack traces in Sentry —
# without these, errors are still captured but point at minified bundle
# code. sentry.io → Settings → find your org/project slugs; Auth Tokens →
# create one scoped to project:releases.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
